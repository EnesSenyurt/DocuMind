# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- LLM ---
# Provider to use for answer generation: gemini | openai | anthropic
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.5-flash
GEMINI_API_KEY=your-gemini-api-key
# Swap the provider above and set the matching key + LLM_MODEL to use another:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Gemini 2.5/3.x "think" and those tokens count against the output budget, so keep
# this generous or answers get cut off mid-sentence.
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60
# Optional, Gemini 3.x only: minimal | low | medium | high (empty = model default).
# Lower = faster replies for grounded Q&A. Gemini 2.5 ignores this.
GEMINI_THINKING_LEVEL=

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Chunking ---
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# --- Retrieval ---
RETRIEVAL_TOP_K=5
# Minimum similarity (0..1) for a chunk to count as relevant.
# Below this for all results -> "I don't have information about this."
RELEVANCE_THRESHOLD=0.25

# --- Conversation ---
# Number of prior messages replayed as chat history for multi-turn context.
MAX_HISTORY_MESSAGES=10

# --- Storage ---
DATA_DIR=./data
