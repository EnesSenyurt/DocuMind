# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- LLM ---
# Provider to use for answer generation: gemini | openai | anthropic
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Chunking ---
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# --- Retrieval ---
RETRIEVAL_TOP_K=5
# Minimum similarity (0..1) for a chunk to count as relevant.
# Below this for all results -> "I don't have information about this."
RELEVANCE_THRESHOLD=0.25

# --- Storage ---
DATA_DIR=./data
