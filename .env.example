# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- LLM ---
# Provider to use for answer generation: gemini | openai | anthropic
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your-gemini-api-key
# Swap the provider above and set the matching key + LLM_MODEL to use another:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=30

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Chunking ---
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# --- Retrieval ---
RETRIEVAL_TOP_K=5
# Minimum similarity (0..1) for a chunk to count as relevant.
# Below this for all results -> "I don't have information about this."
RELEVANCE_THRESHOLD=0.25

# --- Conversation ---
# Number of prior messages replayed as chat history for multi-turn context.
MAX_HISTORY_MESSAGES=10

# --- Storage ---
DATA_DIR=./data
